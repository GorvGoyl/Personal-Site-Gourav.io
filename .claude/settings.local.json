{
    "env": {
        "DISABLE_TELEMETRY": "1",
        "DISABLE_ERROR_REPORTING": "1",
        "DISABLE_BUG_COMMAND": "1"
    },
    "effortLevel": "high",
    "model": "opus",
    "permissions": {
        "allow": [
            "Bash(grep:*)",
            "Bash(xargs:*)",
            "WebSearch",
            "Bash(git:*)",
            "Bash(pnpm run:*)",
            "Bash(npx tsc:*)",
            "mcp__ide__getDiagnostics",
            "Bash(npx tsx:*)",
            "Bash(claude:*)",
            "WebFetch"
        ]
    }
}
